{
  "name": "gutu",
  "version": "0.1.0",
  "private": false,
  "description": "Gutu is a Bun-native, AI-first application platform with a governed admin workbench, explicit contracts, and a clean project workspace generator.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "bin": {
    "gutu": "./dist/gutu.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hyndex/gutu.git"
  },
  "homepage": "https://github.com/hyndex/gutu",
  "bugs": {
    "url": "https://github.com/hyndex/gutu/issues"
  },
  "keywords": [
    "gutu",
    "bun",
    "framework",
    "plugin-system",
    "admin-workbench",
    "ai-first"
  ],
  "files": [
    "dist/gutu.js",
    "framework/**/*",
    "!framework/**/dist",
    "!framework/**/dist/**",
    "!framework/**/*.tsbuildinfo",
    "!framework/**/coverage",
    "!framework/**/coverage/**",
    "!framework/**/artifacts",
    "!framework/**/artifacts/**",
    "!framework/**/node_modules",
    "!framework/**/node_modules/**",
    "tooling/scripts/**/*",
    "tooling/test/**/*",
    "docs/**/*",
    "README.md",
    "LICENSE",
    "Goal.md",
    "Developer_DeepDive.md",
    "bunfig.toml",
    "tsconfig.base.json",
    "tsconfig.json",
    "eslint.config.mjs",
    "prettier.config.mjs"
  ],
  "workspaces": [
    "apps/*",
    "framework/core/*",
    "framework/libraries/*",
    "framework/builtin-plugins/*",
    "tooling/*"
  ],
  "scripts": {
    "scaffold": "bun run tooling/scripts/scaffold-workspace.mjs",
    "gutu": "bun run framework/core/cli/src/bin.ts",
    "platform": "bun run framework/core/cli/src/bin.ts",
    "build:npm:cli": "bun run tooling/scripts/build-gutu-npm-cli.mjs",
    "build": "bun run tooling/scripts/workspace-task.mjs build",
    "typecheck": "bun run tooling/scripts/workspace-task.mjs typecheck",
    "lint": "bun run tooling/scripts/workspace-task.mjs lint",
    "manifests:check": "bun run tooling/scripts/check-package-manifests.mjs",
    "test": "bun run tooling/scripts/workspace-task.mjs test",
    "test:unit": "bun run tooling/scripts/workspace-task.mjs test:unit",
    "test:integration": "bun run tooling/scripts/workspace-task.mjs test:integration",
    "test:e2e": "bun run tooling/scripts/workspace-task.mjs test:e2e",
    "test:contracts": "bun run tooling/scripts/workspace-task.mjs test:contracts",
    "test:migrations": "bun run tooling/scripts/workspace-task.mjs test:migrations",
    "db:render:postgres": "bun run tooling/scripts/render-postgres-assets.mjs",
    "coverage:report": "bun run tooling/scripts/workspace-coverage.mjs",
    "package:release": "bun run tooling/scripts/package-release-bundle.mjs",
    "verify:release-bundle": "bun run tooling/scripts/verify-release-bundle.mjs",
    "sbom:generate": "bun run tooling/scripts/generate-sbom.mjs",
    "provenance:generate": "bun run tooling/scripts/generate-provenance.mjs",
    "sign:artifacts": "bun run tooling/scripts/sign-release-artifacts.mjs",
    "verify:artifacts-signature": "bun run tooling/scripts/verify-release-signature.mjs",
    "security:audit": "bun run tooling/scripts/run-vulnerability-audit.mjs",
    "eval:gate": "bun run tooling/scripts/check-eval-thresholds.mjs",
    "docs:scaffold": "bun run gutu -- docs scaffold --all",
    "docs:index": "bun run gutu -- docs index --all --out docs/agent-understanding.index.json",
    "docs:truth": "bun run tooling/scripts/check-docs-truth.mjs",
    "docs:validate": "bun run gutu -- docs validate --all && bun run docs:truth",
    "ci:check": "bun run build && bun run typecheck && bun run lint && bun run manifests:check && bun run docs:validate && bun run test && bun run test:integration && bun run test:contracts && bun run test:migrations && bun run test:e2e && bun run eval:gate",
    "prepublishOnly": "bun run build:npm:cli"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@hookform/resolvers": "^4.1.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/resources": "^2.1.0",
    "@opentelemetry/sdk-node": "^0.206.0",
    "@opentelemetry/semantic-conventions": "^1.34.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.11",
    "@react-email/components": "^0.0.41",
    "@react-email/render": "^2.0.7",
    "@tanstack/react-query": "^5.75.0",
    "@tanstack/react-router": "^1.120.5",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@tiptap/core": "^2.15.0",
    "@tiptap/react": "^2.15.0",
    "@tiptap/starter-kit": "^2.15.0",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "bullmq": "^5.52.0",
    "bun-types": "^1.3.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "echarts": "^5.6.0",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.0.0",
    "graphql": "^16.11.0",
    "graphql-yoga": "^5.13.5",
    "ioredis": "^5.6.1",
    "lucide-react": "^1.8.0",
    "pino": "^9.7.0",
    "playwright": "^1.52.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.56.2",
    "react-resizable-panels": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.30.1",
    "zod": "^4.0.0"
  }
}

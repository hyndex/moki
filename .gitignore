.DS_Store
**/node_modules/
**/dist/
**/coverage/
**/.gutu/
**/*.tsbuildinfo

# The workspace root is a coordination repo. Standalone extracted repos publish
# from their own git roots and should not be tracked again by the umbrella repo.
/apps/gutu-app-*/
/catalogs/gutu-business-packs/
/catalogs/gutu-libraries/
/catalogs/gutu-plugins/
/gutu-core/
/integrations/gutu-ecosystem-integration/
/libraries/gutu-lib-*/
/plugins/gutu-plugin-*/

# Local or imported reference material is not part of the coordination repo.
/.codex/
/ref/

# Claude Code session-local config (launch.json has absolute paths).
/.claude/

# Graphify durable outputs can be committed; skip only local/runtime byproducts.
graphify-out/cache/
graphify-out/manifest.json
graphify-out/cost.json
graphify-out/needs_update
graphify-out/.graphify_*
gutu-docs/

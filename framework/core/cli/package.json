    "test": "bun test",
    "test:unit": "bun test tests/unit"
  },
  "dependencies": {
    "@platform/ai-guardrails": "workspace:*",
    "@platform/ai-mcp": "workspace:*",
    "@plugins/ai-core": "workspace:*",
    "@plugins/ai-evals": "workspace:*",
    "@plugins/ai-rag": "workspace:*"
  }
}

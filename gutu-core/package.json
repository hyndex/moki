{
  "name": "gutu-core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "description": "Plugin-free core repository for the Gutu ecosystem.",
  "workspaces": [
    "framework/core/*"
  ],
  "bin": {
    "gutu": "./dist/gutu.js"
  },
  "scripts": {
    "gutu": "bun run framework/core/cli/src/bin.ts",
    "doctor": "bun run gutu -- doctor",
    "vendor:sync": "bun run gutu -- vendor sync",
    "rollout:scaffold": "bun run gutu -- rollout scaffold --out ../gutula-rollout",
    "rollout:sync-catalogs": "bun run gutu -- rollout sync-catalogs",
    "build": "bun build framework/core/cli/src/bin.ts --outfile dist/gutu.js --target bun",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "lint": "bunx eslint . --ext .ts",
    "test": "bun test --path-ignore-patterns 'old_contents/*' framework/core",
    "release:prepare": "bun run gutu -- release prepare",
    "release:sign": "bun run gutu -- release sign",
    "release:verify": "bun run gutu -- release verify",
    "ci": "bun run build && bun run typecheck && bun run lint && bun run test && bun run release:prepare"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "bun-types": "^1.3.12",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.30.1",
    "zod": "^3.24.3"
  }
}

    "cmdk": "^1.0.4",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "hast-util-to-html": "^9.0.5",
    "leaflet": "^1.9.4",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "tippy.js": "^6.3.7",
    "y-indexeddb": "^9.0.12",
    "y-prosemirror": "^1.2.15",

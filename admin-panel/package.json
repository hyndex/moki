{
  "name": "@gutu/admin-panel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Universal Gutu admin panel — tiered, contract-driven, plugin-friendly.",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:ui": "vite",
    "dev:api": "cd backend && bun run dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "//gutuPlugins": "Frontend plugin auto-discovery: every entry is the npm name of a plugin shipping `host-plugin/ui/index.ts` with an `adminUi` export. The shell auto-imports each at boot. Add a UI plugin: `bun add @acme/gutu-foo` + add the name here.",
  "gutuPlugins": [
    "@gutu-plugin/forms-core",
    "@gutu-plugin/template-core",
    "@gutu-plugin/notifications-core",
    "@gutu-plugin/integration-core",
    "@gutu-plugin/webhooks-core",
    "@gutu-plugin/auth-core",
    "@gutu-plugin/workflow-core"
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tanstack/react-table": "^8.21.2",
    "@tiptap/core": "^2.10.4",
    "@tiptap/extension-character-count": "^2.10.4",
    "@tiptap/extension-code-block-lowlight": "^2.10.4",
    "@tiptap/extension-collaboration": "^2.10.4",
    "@tiptap/extension-collaboration-cursor": "^2.26.2",
    "@tiptap/extension-color": "^2.10.4",
    "@tiptap/extension-highlight": "^2.10.4",
    "@tiptap/extension-image": "^2.10.4",
    "@tiptap/extension-link": "^2.10.4",
    "@tiptap/extension-placeholder": "^2.10.4",
    "@tiptap/extension-table": "^2.10.4",
    "@tiptap/extension-table-cell": "^2.10.4",
    "@tiptap/extension-table-header": "^2.10.4",
    "@tiptap/extension-table-row": "^2.10.4",
    "@tiptap/extension-task-item": "^2.10.4",
    "@tiptap/extension-task-list": "^2.10.4",
    "@tiptap/extension-text-align": "^2.10.4",
    "@tiptap/extension-text-style": "^2.10.4",
    "@tiptap/extension-typography": "^2.10.4",
    "@tiptap/extension-underline": "^2.10.4",
    "@tiptap/pm": "^2.10.4",
    "@tiptap/react": "^2.10.4",
    "@tiptap/starter-kit": "^2.10.4",
    "@tiptap/suggestion": "^2.10.4",
    "@types/hast": "^3.0.4",
    "@types/leaflet": "^1.9.21",
    "@univerjs/preset-docs-core": "^0.21.0",

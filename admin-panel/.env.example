# ----------------------------------------------------------------------
# Gutu Admin Panel — backend configuration
#
# Three supported modes:
#   1. SQLite single-site  (default; zero-config dev)
#   2. Postgres single-site (production, one tenant)
#   3. Postgres multi-site  (production, many tenants, schema-per-tenant)
# ----------------------------------------------------------------------

# ---- Common -----------------------------------------------------------

# Port the Hono API listens on (Vite proxies /api/* to this).
API_PORT=3333

# Path to the SQLite file (single-site SQLite only). Falls back to
# admin-panel/backend/data.db if unset.
# DB_PATH=/absolute/path/to/data.db

# Where per-tenant file uploads are stored on disk.
# Each tenant gets a subdirectory named after its schema.
# FILES_ROOT=/absolute/path/to/files

# ---- Mode 1 — SQLite single-site (DEFAULT) ----------------------------

# Nothing to set. The server boots into SQLite + single-site with a
# default tenant named "Main". The WorkspaceSwitcher self-hides when
# there's only one tenant, so the UI looks identical to pre-multisite.

# ---- Mode 2 — Postgres single-site ------------------------------------

# DB_KIND=postgres
# DATABASE_URL=postgres://user:pass@localhost:5432/gutu
# PG_MAX_POOL=10
# MULTISITE=0

# ---- Mode 3 — Postgres multi-site -------------------------------------

# DB_KIND=postgres
# DATABASE_URL=postgres://user:pass@localhost:5432/gutu
# MULTISITE=1

# How requests identify their tenant: subdomain | header | path
# TENANT_RESOLUTION=subdomain

# Root domain for subdomain resolution (e.g. "gutu.app" → "acme.gutu.app"
# maps to the tenant with slug "acme").
# ROOT_DOMAIN=gutu.app

# Header name for header-based resolution.
# TENANT_HEADER=x-tenant

# Path prefix for path-based resolution (requests to /t/<slug>/... resolve
# to the tenant with that slug).
# TENANT_PATH_PREFIX=/t

# Slug of the fallback tenant when the resolver finds no match.
# DEFAULT_TENANT_SLUG=main

# Prefix for auto-generated Postgres schema names.
# TENANT_SCHEMA_PREFIX=tenant_

# Email of a super-admin who can manage any tenant regardless of membership.
# SUPER_ADMIN_EMAIL=chinmoy@gutu.dev

# ---- Seed ------------------------------------------------------------

# SEED_FORCE=1 wipes and re-seeds demo data at boot.
# SEED_FORCE=0

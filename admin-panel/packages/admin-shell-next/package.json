{
  "name": "@gutu/admin-shell-next",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Next-generation Gutu admin shell — schema-driven framework with a plugin-friendly API. Coexists with @platform/admin-contracts via @gutu/admin-shell-bridge.",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./builders": {
      "types": "./src/builders.ts",
      "import": "./src/builders.ts"
    },
    "./contracts": {
      "types": "./src/contracts.ts",
      "import": "./src/contracts.ts"
    },
    "./runtime": {
      "types": "./src/runtime.ts",
      "import": "./src/runtime.ts"
    },
    "./shell": {
      "types": "./src/shell.ts",
      "import": "./src/shell.ts"
    },
    "./admin-primitives": {
      "types": "./src/admin-primitives.ts",
      "import": "./src/admin-primitives.ts"
    },
    "./widgets": {
      "types": "./src/widgets.ts",
      "import": "./src/widgets.ts"
    },
    "./host": {
      "types": "./src/host.ts",
      "import": "./src/host.ts"
    }
  },
  "keywords": [
    "gutu",
    "admin",
    "plugin",
    "framework",
    "schema-driven"

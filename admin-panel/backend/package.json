{
  "name": "@gutu/admin-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Real REST backend for the Gutu admin panel. Bun + Hono + SQLite.",
  "scripts": {
    "dev": "bun run --hot src/main.ts",
    "start": "bun run src/main.ts",
    "seed": "bun run src/seed/run.ts",
    "reset": "rm -f data.db && bun run seed",
    "typecheck": "tsc --noEmit"
  },
  "//gutuPlugins": "Decentralized plugin discovery: every entry is a package import specifier the loader auto-imports at boot. Add a plugin: `bun add @acme/gutu-foo` + add the name here. Override at runtime via env GUTU_PLUGINS=...",
  "gutuPlugins": [
    "@gutu-plugin/template-core",
    "@gutu-plugin/notifications-core",
    "@gutu-plugin/pricing-tax-core",
    "@gutu-plugin/accounting-core",
    "@gutu-plugin/inventory-core",
    "@gutu-plugin/manufacturing-core",
    "@gutu-plugin/sales-core",
    "@gutu-plugin/treasury-core",
    "@gutu-plugin/hr-payroll-core",
    "@gutu-plugin/e-invoicing-core",
    "@gutu-plugin/forms-core",
    "@gutu-plugin/integration-core",
    "@gutu-plugin/analytics-bi-core",
    "@gutu-plugin/field-metadata-core",
    "@gutu-plugin/auth-core",
    "@gutu-plugin/webhooks-core",
    "@gutu-plugin/workflow-core",
    "@gutu-plugin/saved-views-core",
    "@gutu-plugin/timeline-core",
    "@gutu-plugin/favorites-core",
    "@gutu-plugin/record-links-core",
    "@gutu-plugin/erp-actions-core",
    "@gutu-plugin/awesome-search-core",
    "@gutu-plugin/editor-core",
    "@gutu-plugin/connections-core"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.645.0",
    "@aws-sdk/s3-request-presigner": "^3.645.0",
    "hono": "^4.6.14",
    "lib0": "^0.2.117",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.3"
  }
}

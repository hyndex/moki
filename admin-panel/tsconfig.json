{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@gutu/admin-shell-next": ["packages/admin-shell-next/src/index.ts"],
      "@gutu/admin-shell-next/*": ["packages/admin-shell-next/src/*"],
      "@gutu/admin-shell-bridge": ["packages/admin-shell-bridge/src/index.ts"],
      "@gutu/admin-shell-bridge/*": ["packages/admin-shell-bridge/src/*"]
    }
  },
  "include": ["src", "vite.config.ts", "packages/*/src"]
}
